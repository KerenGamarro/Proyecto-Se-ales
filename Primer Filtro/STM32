/*
 * PROYECTO FINAL - ETAPA 3
 * Comunicación STM32 Nucleo-F446RE con Matlab
 *
 * Comandos:
 * C        -> Captura 1000 muestras y las envía a Matlab
 * L,0.90   -> Cambia lambda del filtro IIR
 *
 * Fs = 1000 Hz
 */
/* USER CODE END Header */

#include "main.h"

/* USER CODE BEGIN Includes */
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
/* USER CODE END Includes */

ADC_HandleTypeDef hadc1;
DAC_HandleTypeDef hdac;
TIM_HandleTypeDef htim10;
UART_HandleTypeDef huart2;

/* USER CODE BEGIN PV */

#define N_SAMPLES 1000

uint16_t adc_value = 0;
uint16_t adc_buffer[N_SAMPLES];

volatile uint16_t sample_index = 0;
volatile uint8_t capture_active = 0;
volatile uint8_t capture_done = 0;

uint8_t rx_data;
char rx_buffer[40];
uint8_t rx_index = 0;

char uart_buffer[50];
uint16_t uart_len = 0;

uint16_t Fs = 1000;

uint32_t timer_clk;
uint32_t pclk;

// Filtro IIR H1:
// y[n] = (1 - lambda)x[n] + lambda*y[n-1]
float lambda = 0.90f;
float x_n = 0.0f;
float y_n = 0.0f;
float y_n_1 = 0.0f;

/* USER CODE END PV */

void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
static void MX_ADC1_Init(void);
static void MX_TIM10_Init(void);
static void MX_DAC_Init(void);

/* USER CODE BEGIN 0 */

void procesar_comando(char *cmd)
{
	if (cmd[0] == 'C')
	{
		HAL_UART_Transmit(&huart2, (uint8_t*)"OK_CAPTURA\r\n", 12, HAL_MAX_DELAY);

		sample_index = 0;
		capture_done = 0;
		capture_active = 1;
	}

	else if (cmd[0] == 'L')
	{
		float nuevo_lambda = atof(&cmd[2]);

		if (nuevo_lambda >= 0.0f && nuevo_lambda < 1.0f)
		{
			lambda = nuevo_lambda;

			uart_len = sprintf(uart_buffer, "OK_LAMBDA,%.3f\r\n", lambda);
			HAL_UART_Transmit(&huart2, (uint8_t*)uart_buffer, uart_len, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_LAMBDA\r\n", 12, HAL_MAX_DELAY);
		}
	}
}

void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
	if (htim->Instance == TIM10)
	{
		if (capture_active == 1)
		{
			HAL_ADC_Start(&hadc1);
			HAL_ADC_PollForConversion(&hadc1, 10);
			adc_value = HAL_ADC_GetValue(&hadc1);

			x_n = (float)adc_value;

			y_n = (1.0f - lambda)*x_n + lambda*y_n_1;
			y_n_1 = y_n;

			if (y_n > 4095.0f) y_n = 4095.0f;
			if (y_n < 0.0f)    y_n = 0.0f;

			adc_buffer[sample_index] = (uint16_t)y_n;

			HAL_DAC_SetValue(&hdac, DAC_CHANNEL_1, DAC_ALIGN_12B_R, (uint16_t)y_n);

			sample_index++;

			if (sample_index >= N_SAMPLES)
			{
				capture_active = 0;
				capture_done = 1;
			}
		}
	}
}

/* USER CODE END 0 */

int main(void)
{
  HAL_Init();

  SystemClock_Config();

  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_ADC1_Init();
  MX_TIM10_Init();
  MX_DAC_Init();

  HAL_DAC_Start(&hdac, DAC_CHANNEL_1);
  HAL_TIM_Base_Start_IT(&htim10);

  while (1)
  {
	  if (HAL_UART_Receive(&huart2, &rx_data, 1, 10) == HAL_OK)
	  {
		  if (rx_data == '\n' || rx_data == '\r')
		  {
			  if (rx_index > 0)
			  {
				  rx_buffer[rx_index] = '\0';
				  procesar_comando(rx_buffer);
				  rx_index = 0;
			  }
		  }
		  else
		  {
			  if (rx_index < sizeof(rx_buffer) - 1)
			  {
				  rx_buffer[rx_index++] = rx_data;
			  }
		  }
	  }

	  if (capture_done == 1)
	  {
		  capture_done = 0;

		  HAL_UART_Transmit(&huart2, (uint8_t*)"BEGIN\r\n", 7, HAL_MAX_DELAY);

		  for (uint16_t i = 0; i < N_SAMPLES; i++)
		  {
			  uart_len = sprintf(uart_buffer, "%u\r\n", adc_buffer[i]);
			  HAL_UART_Transmit(&huart2, (uint8_t*)uart_buffer, uart_len, HAL_MAX_DELAY);
		  }

		  HAL_UART_Transmit(&huart2, (uint8_t*)"END\r\n", 5, HAL_MAX_DELAY);
	  }
  }
}

