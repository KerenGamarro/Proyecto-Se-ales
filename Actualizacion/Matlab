        % Button pushed function: DisearFIRButton
        function DisearFIRButtonPushed(app, event)

            Fs = app.Fs;
            orden = round(app.OrdenEditField_3.Value);
            Fc1 = app.Fc1EditField.Value;
            Fc2 = app.Fc2EditField.Value;
            tipo = app.TipodeFiltroDropDown.Value;
        
            Fn = Fs/2;   % Frecuencia de Nyquist
        
            % Validar orden
            if orden < 2
                uialert(app.UIFigure, "El orden del filtro FIR debe ser mayor o igual a 2.", "Orden inválido");
                return;
            end
        
            % Validar Fc1
            if Fc1 <= 0 || Fc1 >= Fn
                uialert(app.UIFigure, "Fc1 debe estar entre 0 y Fs/2.", "Frecuencia inválida");
                return;
            end
        
            try
                switch tipo
        
                    case "Low Pass"
        
                        Wn = Fc1/Fn;
                        app.b = fir1(orden, Wn, "low");
                        app.a = 1;
        
                    case "High Pass"
        
                        Wn = Fc1/Fn;
                        app.b = fir1(orden, Wn, "high");
                        app.a = 1;
        
                    case "Pass Band"
        
                        if Fc2 <= Fc1 || Fc2 >= Fn
                            uialert(app.UIFigure, ...
                                "Para Pass Band debe cumplirse: 0 < Fc1 < Fc2 < Fs/2.", ...
                                "Frecuencias inválidas");
                            return;
                        end
        
                        Wn = [Fc1 Fc2]/Fn;
                        app.b = fir1(orden, Wn, "bandpass");
                        app.a = 1;
        
                    case "Remove Band"
        
                        if Fc2 <= Fc1 || Fc2 >= Fn
                            uialert(app.UIFigure, ...
                                "Para Remove Band debe cumplirse: 0 < Fc1 < Fc2 < Fs/2.", ...
                                "Frecuencias inválidas");
                            return;
                        end
        
                        Wn = [Fc1 Fc2]/Fn;
                        app.b = fir1(orden, Wn, "stop");
                        app.a = 1;
                end
        
                app.filtroDisenado = true;
                app.tipoFiltroDisenado = "FIR";
        
                mostrarCoeficientes(app);
                graficarRespuestaFiltro(app);
        
                app.FIRlistoLabel.Text = "FIR diseñado";
                app.EstadoLabel.Text = "Filtro FIR diseñado";
        
            catch ME
        
                uialert(app.UIFigure, ...
                    "No se pudo diseñar el filtro FIR." + newline + ME.message, ...
                    "Error FIR");
        
                app.FIRlistoLabel.Text = "Error FIR";
                app.EstadoLabel.Text = "Error al diseñar FIR";
            end
        end

        % Button pushed function: DisearIIRButton
        function DisearIIRButtonPushed(app, event)


            Fs = app.Fs;
            orden = round(app.OrdenEditField_2.Value);
            Fc = app.FcEditField.Value;
            ripple = app.RippleEditField.Value;
            atenuacion = app.AtenuacinEditField.Value;
            tipo = app.TipoFiltroDropDown_2.Value;
        
            Fn = Fs/2;   % Frecuencia de Nyquist
        
            if orden < 1 || orden > 10
                uialert(app.UIFigure, "El orden del filtro IIR debe estar entre 1 y 10.", "Orden inválido");
                return;
            end
        
            if Fc <= 0 || Fc >= Fn
                uialert(app.UIFigure, "Fc debe estar entre 0 y Fs/2.", "Frecuencia inválida");
                return;
            end
        
            if ripple <= 0
                uialert(app.UIFigure, "El ripple debe ser mayor que 0 dB.", "Ripple inválido");
                return;
            end
        
            if atenuacion <= 0
                uialert(app.UIFigure, "La atenuación debe ser mayor que 0 dB.", "Atenuación inválida");
                return;
            end
        
            try
                Wn = Fc/Fn;
        
                switch tipo
        
                    case "Butterworth"
                        [app.b, app.a] = butter(orden, Wn, "low");
        
                    case "Chebyshev I"
                        [app.b, app.a] = cheby1(orden, ripple, Wn, "low");
        
                    case "Chebyshev II"
                        [app.b, app.a] = cheby2(orden, atenuacion, Wn, "low");
        
                    case "Elliptic"
                        [app.b, app.a] = ellip(orden, ripple, atenuacion, Wn, "low");
                    
                    case "Bessel"
                    
                        % Para Bessel se diseña primero un filtro analógico
                        % y luego se convierte a digital con transformación bilineal.
                    
                        Wc = 2*pi*Fc;                 % Frecuencia de corte analógica en rad/s
                    
                        [ba, aa] = besself(orden, Wc); % Filtro Bessel analógico
                    
                        [app.b, app.a] = bilinear(ba, aa, Fs); % Conversión a filtro digital
                end
        
                app.filtroDisenado = true;
                app.tipoFiltroDisenado = "IIR";
        
                mostrarCoeficientes(app);
                graficarRespuestaFiltro(app);
        
                app.IIRlistoLabel.Text = "IIR diseñado";
                app.EstadoLabel.Text = "Filtro IIR diseñado";
                        
            catch ME
        
                uialert(app.UIFigure, ...
                    "No se pudo diseñar el filtro IIR." + newline + ME.message, ...
                    "Error IIR");
        
               app.IIRlistoLabel.Text = "Error IIR";
               app.EstadoLabel.Text = "Error al diseñar IIR";
        
            end
        end

        % Button pushed function: EnviarCoeficientesButton
        function EnviarCoeficientesButtonPushed(app, event)
        
            if app.conectado == false
                uialert(app.UIFigure, "Primero conecta la Nucleo.", "Error");
                return;
            end
        
            if app.filtroDisenado == false
                uialert(app.UIFigure, "Primero diseña un filtro IIR.", "Sin filtro");
                return;
            end
        
            try
                flush(app.s);
        
                b = app.b(:).';
                a = app.a(:).';
        
                Nb = length(b);
                Na = length(a);
        
                % ======================================================
                % Enviar número de coeficientes b
                % ======================================================
                writeline(app.s, sprintf("NB,%d", Nb));
                resp = strtrim(readline(app.s));
        
                if resp ~= "OK_NB"
                    uialert(app.UIFigure, "La Nucleo no aceptó NB. Respuesta: " + resp, "Error");
                    return;
                end
        
                % ======================================================
                % Enviar coeficientes b
                % IMPORTANTE: la STM32 espera índices desde 1
                % ======================================================
                for k = 1:Nb
        
                    writeline(app.s, sprintf("B,%d,%.10f", k, b(k)));
                    resp = strtrim(readline(app.s));
        
                    if resp ~= "OK_B"
                        uialert(app.UIFigure, ...
                            "Error enviando B(" + string(k) + "). Respuesta: " + resp, ...
                            "Error");
                        return;
                    end
        
                end
        
                % ======================================================
                % Enviar número de coeficientes a
                % ======================================================
                writeline(app.s, sprintf("NA,%d", Na));
                resp = strtrim(readline(app.s));
        
                if resp ~= "OK_NA"
                    uialert(app.UIFigure, "La Nucleo no aceptó NA. Respuesta: " + resp, "Error");
                    return;
                end
        
                % ======================================================
                % Enviar coeficientes a
                % IMPORTANTE: la STM32 espera índices desde 1
                % ======================================================
                for k = 1:Na
        
                    writeline(app.s, sprintf("A,%d,%.10f", k, a(k)));
                    resp = strtrim(readline(app.s));
        
                    if resp ~= "OK_A"
                        uialert(app.UIFigure, ...
                            "Error enviando A(" + string(k) + "). Respuesta: " + resp, ...
                            "Error");
                        return;
                    end
        
                end
        
               % Confirmar fin de coeficientes
                writeline(app.s, "END_COEF");
                resp = strtrim(readline(app.s));
                
                if resp == "OK_COEF"
                    app.EstadoLabel.Text = "Coeficientes IIR cargados en Nucleo";
                else
                    app.EstadoLabel.Text = "Error coeficientes";
                end
        
            catch ME
        
                uialert(app.UIFigure, ...
                    "No se pudieron enviar los coeficientes." + newline + ME.message, ...
                    "Error UART");
        
                app.EstadoLabel.Text = "Error al enviar coeficientes";
        
            end
        end

