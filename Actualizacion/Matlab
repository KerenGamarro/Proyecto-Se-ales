        % Button pushed function: AplicarEfectoButton
        function AplicarEfectoButtonPushed(app, event)

            if isempty(app.x)
                uialert(app.UIFigure, "Primero carga o captura una señal.", "Sin señal");
                return;
            end
        
            efecto = app.EfectoDropDown.Value;
        
            Fs = app.Fs;
            x = app.x(:).';      % Asegurar vector fila
            N = length(x);
        
            tiempoDelay = app.TiempoDelayEditField.Value;
            ganancia = app.GananciaEditField.Value;
            nivelDist = app.NiveldedistorsinEditField.Value;
        
            try
                switch efecto
        
                    case "Ganancia"
        
                        % Multiplica la señal por una ganancia
                        app.y = ganancia * x;
        
                        app.EstadoLabel.Text = "Efecto Ganancia aplicado";
        
                    case "Delay"
        
                        % Retardo puro de la señal
                        muestrasDelay = round(tiempoDelay * Fs);
        
                        if muestrasDelay <= 0
                            uialert(app.UIFigure, "El tiempo de delay debe ser mayor que 0.", "Delay inválido");
                            return;
                        end
        
                        if muestrasDelay >= N
                            uialert(app.UIFigure, "El delay es demasiado grande para la longitud de la señal.", "Delay inválido");
                            return;
                        end
        
                        app.y = [zeros(1, muestrasDelay), x(1:end-muestrasDelay)];
        
                        app.EstadoLabel.Text = "Efecto Delay aplicado";
        
                    case "Eco"
        
                        % Eco = señal original + copia retardada atenuada
                        muestrasDelay = round(tiempoDelay * Fs);
        
                        if muestrasDelay <= 0
                            uialert(app.UIFigure, "El tiempo de eco debe ser mayor que 0.", "Eco inválido");
                            return;
                        end
        
                        if muestrasDelay >= N
                            uialert(app.UIFigure, "El delay del eco es demasiado grande para la señal.", "Eco inválido");
                            return;
                        end
        
                        eco = [zeros(1, muestrasDelay), x(1:end-muestrasDelay)];
        
                        app.y = x + ganancia * eco;
        
                        % Normalización para evitar que la señal crezca demasiado
                        maxOriginal = max(abs(x - mean(x)));
                        maxProcesada = max(abs(app.y - mean(app.y)));
        
                        if maxProcesada > 0 && maxOriginal > 0
                            app.y = (app.y - mean(app.y)) * (maxOriginal / maxProcesada) + mean(x);
                        end
        
                        app.EstadoLabel.Text = "Efecto Eco aplicado";
        
                    case "Distorsión"
        
                        % Distorsión tipo saturación suave usando tanh()
                        x0 = x - mean(x);
        
                        maxAbs = max(abs(x0));
        
                        if maxAbs == 0
                            uialert(app.UIFigure, "La señal es constante; no se puede distorsionar adecuadamente.", "Señal inválida");
                            return;
                        end
        
                        xNorm = x0 / maxAbs;
        
                        if nivelDist <= 0
                            nivelDist = 1;
                        end
        
                        yNorm = tanh(nivelDist * xNorm);
        
                        % Reescalar a amplitud similar a la original
                        app.y = yNorm * maxAbs + mean(x);
        
                        app.EstadoLabel.Text = "Efecto Distorsión aplicado";
        
                end
        
                % Graficar señal original/procesada en tiempo
                graficarTiempo(app);
                
                % Actualizar frecuencia
                actualizarFrecuencia(app);
                
                % Si la señal cargada es audio, actualizar también la pestaña Audio
                if app.audioCargado == true
                    graficarAudio(app);
                end
        
                % Actualizar frecuencia
                actualizarFrecuencia(app);
        
            catch ME
        
                uialert(app.UIFigure, ...
                    "No se pudo aplicar el efecto." + newline + ME.message, ...
                    "Error de efecto");
        
                app.EstadoLabel.Text = "Error al aplicar efecto";
        
            end
        end

        % Button pushed function: GuardarCSVButton
        function GuardarCSVButtonPushed(app, event)

            if isempty(app.x)
                uialert(app.UIFigure, "No hay señal original para guardar.", "Sin datos");
                return;
            end
        
            % Seleccionar nombre y ubicación
            [file, path] = uiputfile("*.csv", "Guardar datos como CSV");
        
            if isequal(file, 0)
                return;
            end
        
            archivo = fullfile(path, file);
        
            x = app.x(:);
            Fs = app.Fs;
        
            % Si no hay señal procesada, se guarda como NaN
            if isempty(app.y)
                y = NaN(size(x));
            else
                y = app.y(:);
            end
        
            % Igualar longitudes por seguridad
            L = max(length(x), length(y));
        
            x_pad = NaN(L, 1);
            y_pad = NaN(L, 1);
        
            x_pad(1:length(x)) = x;
            y_pad(1:length(y)) = y;
        
            n = (0:L-1).';
            t = n/Fs;
        
            tabla = table(n, t, x_pad, y_pad, ...
                'VariableNames', {'Muestra', 'Tiempo_s', 'Original', 'Procesada'});
        
            try
                writetable(tabla, archivo);
        
                app.EstadoLabel.Text = "CSV guardado";
        
            catch ME
                uialert(app.UIFigure, ...
                    "No se pudo guardar el archivo CSV." + newline + ME.message, ...
                    "Error CSV");
        
                app.EstadoLabel.Text = "Error al guardar CSV";
            end
        end

