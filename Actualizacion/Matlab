    methods (Access = private)
        
        function startupFcn(app)

            % Configuración inicial de conexión
            app.conectado = false;
            app.EstadoLabel.Text = "Desconectado";
            app.StatusLamp.Color = [1 0 0];
        
            % Configuración de toma de datos
            app.NumerodemuestrasEditField.Limits = [100 5000];
            app.NumerodemuestrasEditField.Value = 1000;
            app.NumerodemuestrasEditField.RoundFractionalValues = "on";
        
            app.FsHzEditField.Limits = [100 5000];
            app.FsHzEditField.Value = 1000;
            app.FsHzEditField.RoundFractionalValues = "on";
        
            % Canal ADC usado por el potenciómetro
            app.CanalADCDropDown.Items = {'A0 / PA0'};
            app.CanalADCDropDown.ItemsData = {'A0'};
            app.CanalADCDropDown.Value = 'A0';
        
            % Lambda del filtro IIR
            app.LambdaEditField.Limits = [0 0.99];
            app.LambdaEditField.Value = 0.90;
        
            % Valores internos
            app.Fs = 1000;
            app.N = 1000;
            app.x = [];
            app.y = [];
            app.datosCapturados = [];
        
            app.b = 1;
            app.a = 1;
            app.filtroDisenado = false;
            app.tipoFiltroDisenado = "";
        
            % Configuración inicial FIR
            app.OrdenEditField_3.Limits = [2 200];
            app.OrdenEditField_3.Value = 50;
            app.OrdenEditField_3.RoundFractionalValues = "on";
        
            app.Fc1EditField.Limits = [1 app.Fs/2 - 1];
            app.Fc1EditField.Value = 50;
        
            app.Fc2EditField.Limits = [1 app.Fs/2 - 1];
            app.Fc2EditField.Value = 150;
        
            app.TipodeFiltroDropDown.Items = {'Low Pass', 'High Pass', 'Pass Band', 'Remove Band'};
            app.TipodeFiltroDropDown.Value = 'Low Pass';
        
            app.FIRlistoLabel.Text = "FIR listo";
                            
        end

        function graficarTiempo(app)

            if isempty(app.x)
                return;
            end
        
            app.Fs = app.Fs;
        
            x0 = app.x - mean(app.x);
        
            % Forzar vector fila
            x0 = x0(:).';
        
            app.N = length(x0);
            t = (0:app.N-1)/app.Fs;
        
            disp(size(t))
            disp(size(x0))
        
            plot(app.UIAxes, t, x0, "LineWidth",1.2);
        
            grid(app.UIAxes,"on");
            title(app.UIAxes,"Señal original centrada");
            xlabel(app.UIAxes,"Tiempo [s]");
            ylabel(app.UIAxes,"Amplitud");
        
            xlim(app.UIAxes,[0 t(end)]);
            yline(app.UIAxes,0,"k");
        
            ymin = min(x0);
            ymax = max(x0);
        
            margen = 0.1*(ymax-ymin);
        
            if margen==0
                margen=1;
            end
        
            ylim(app.UIAxes,[ymin-margen ymax+margen]);
        
            if ~isempty(app.y)
        
                y0 = app.y - mean(app.y);
        
                % Forzar vector fila
                y0 = y0(:).';
        
                Ny = length(y0);
                ty = (0:Ny-1)/app.Fs;
        
                plot(app.UIAxes2,ty,y0,"LineWidth",1.2);
        
                grid(app.UIAxes2,"on");
                title(app.UIAxes2,"Señal procesada centrada");
                xlabel(app.UIAxes2,"Tiempo [s]");
                ylabel(app.UIAxes2,"Amplitud");
        
                xlim(app.UIAxes2,[0 ty(end)]);
                yline(app.UIAxes2,0,"k");
        
                ymin=min(y0);
                ymax=max(y0);
        
                margen=0.1*(ymax-ymin);
        
                if margen==0
                    margen=1;
                end
        
                ylim(app.UIAxes2,[ymin-margen ymax+margen]);
            end
        
        end
        
        function procesarConLambda(app)
        
            if isempty(app.x)
                uialert(app.UIFigure, "No hay señal original para procesar.", "Sin datos");
                return;
            end
        
            lambda = app.LambdaEditField.Value;
        
            if lambda < 0 || lambda >= 1
                uialert(app.UIFigure, "Lambda debe estar entre 0 y menor que 1.", "Valor inválido");
                return;
            end
        
            b = 1 - lambda;
            a = [1 -lambda];
        
            app.y = filter(b, a, app.x);
        
            graficarTiempo(app);
            actualizarFrecuencia(app);
        
        end
        
        
        function [f, mag, fase] = espectroUnilateral(app, senal, Fs)
        
            senal = senal(:);
            senal = senal - mean(senal);   % Quitar componente DC
        
            N = length(senal);
        
            Y = fft(senal);
        
            P2 = abs(Y/N);
            mag = P2(1:floor(N/2)+1);
        
            if length(mag) > 2
                mag(2:end-1) = 2*mag(2:end-1);
            end
        
            faseCompleta = angle(Y);
            fase = faseCompleta(1:floor(N/2)+1);
        
            f = Fs*(0:floor(N/2))/N;
        
        end
            
        function mostrarCoeficientes(app)

            if isempty(app.b)
                app.CoeficientesbEditField.Value = "";
            else
                app.CoeficientesbEditField.Value = mat2str(app.b, 6);
            end
        
            if isempty(app.a)
                app.CoeficientesaEditField_2.Value = "";
            else
                app.CoeficientesaEditField_2.Value = mat2str(app.a, 6);
            end
        
        end

        function graficarRespuestaFiltro(app)

            if isempty(app.b) || isempty(app.a)
                return;
            end
        
            Fs = app.Fs;
        
            [h, w] = freqz(app.b, app.a, 1024);
        
            % ============================================================
            % Selección del eje horizontal
            % ============================================================
            if app.radmuestraCheckBox.Value == true
        
                eje = w;
                etiquetaX = "Frecuencia [rad/muestra]";
                limiteX = pi;
        
            else
        
                eje = w*Fs/(2*pi);
                etiquetaX = "Frecuencia [Hz]";
                limiteX = Fs/2;
        
            end
        
            % ============================================================
            % Magnitud normal o en dB
            % ============================================================
            magnitud = abs(h);
        
            if app.MostrardbCheckBox.Value == true
        
                magnitud = 20*log10(magnitud + eps);
                etiquetaYMag = "Magnitud [dB]";
        
            else
        
                etiquetaYMag = "Magnitud";
        
            end
        
            % ============================================================
            % Fase
            % ============================================================
            fase = rad2deg(unwrap(angle(h)));
        
            % ============================================================
            % Respuesta en magnitud del filtro
            % ============================================================
            plot(app.UIAxes_4, eje, magnitud, "LineWidth", 1.2);
            grid(app.UIAxes_4, "on");
            title(app.UIAxes_4, "Respuesta en frecuencia - Magnitud");
            xlabel(app.UIAxes_4, etiquetaX);
            ylabel(app.UIAxes_4, etiquetaYMag);
            xlim(app.UIAxes_4, [0 limiteX]);
        
            % ============================================================
            % Respuesta en fase del filtro
            % ============================================================
            plot(app.UIAxes_5, eje, fase, "LineWidth", 1.2);
            grid(app.UIAxes_5, "on");
            title(app.UIAxes_5, "Respuesta en frecuencia - Fase");
            xlabel(app.UIAxes_5, etiquetaX);
            ylabel(app.UIAxes_5, "Fase [°]");
            xlim(app.UIAxes_5, [0 limiteX]);
        
        end
        function graficarAudio(app)

            if isempty(app.x)
                return;
            end
        
            Fs = app.Fs;
        
            % ============================================================
            % Audio original en tiempo
            % UIAxes_6 = arriba izquierda
            % ============================================================
            x = app.x(:).';
            N = length(x);
            t = (0:N-1)/Fs;
        
            plot(app.UIAxes_6, t, x, "LineWidth", 1.0);
            grid(app.UIAxes_6, "on");
            title(app.UIAxes_6, "Audio original - Tiempo");
            xlabel(app.UIAxes_6, "Tiempo [s]");
            ylabel(app.UIAxes_6, "Amplitud");
        
            if ~isempty(t)
                xlim(app.UIAxes_6, [0 t(end)]);
            end
        
            % ============================================================
            % Espectro audio original
            % UIAxes_8 = abajo izquierda
            % ============================================================
            [f1, mag1, ~] = espectroUnilateral(app, x, Fs);
        
            plot(app.UIAxes_8, f1, mag1, "LineWidth", 1.0);
            grid(app.UIAxes_8, "on");
            title(app.UIAxes_8, "Espectro audio original");
            xlabel(app.UIAxes_8, "Frecuencia [Hz]");
            ylabel(app.UIAxes_8, "|X(f)|");
            xlim(app.UIAxes_8, [0 Fs/2]);
        
            if max(mag1) > 0
                ylim(app.UIAxes_8, [0 max(mag1)*1.1]);
            end
        
            % ============================================================
            % Audio procesado si existe
            % UIAxes_7 = arriba derecha
            % UIAxes_9 = abajo derecha
            % ============================================================
            if ~isempty(app.y)
        
                y = app.y(:).';
                Ny = length(y);
                ty = (0:Ny-1)/Fs;
        
                plot(app.UIAxes_7, ty, y, "LineWidth", 1.0);
                grid(app.UIAxes_7, "on");
                title(app.UIAxes_7, "Audio procesado - Tiempo");
                xlabel(app.UIAxes_7, "Tiempo [s]");
                ylabel(app.UIAxes_7, "Amplitud");
        
                if ~isempty(ty)
                    xlim(app.UIAxes_7, [0 ty(end)]);
                end
        
                [f2, mag2, ~] = espectroUnilateral(app, y, Fs);
        
                plot(app.UIAxes_9, f2, mag2, "LineWidth", 1.0);
                grid(app.UIAxes_9, "on");
                title(app.UIAxes_9, "Espectro audio procesado");
                xlabel(app.UIAxes_9, "Frecuencia [Hz]");
                ylabel(app.UIAxes_9, "|Y(f)|");
                xlim(app.UIAxes_9, [0 Fs/2]);
        
                if max(mag2) > 0
                    ylim(app.UIAxes_9, [0 max(mag2)*1.1]);
                end
        
            else
        
                cla(app.UIAxes_7);
                cla(app.UIAxes_9);
        
                title(app.UIAxes_7, "Audio procesado - Tiempo");
                xlabel(app.UIAxes_7, "Tiempo [s]");
                ylabel(app.UIAxes_7, "Amplitud");
                grid(app.UIAxes_7, "on");
        
                title(app.UIAxes_9, "Espectro audio procesado");
                xlabel(app.UIAxes_9, "Frecuencia [Hz]");
                ylabel(app.UIAxes_9, "|Y(f)|");
                grid(app.UIAxes_9, "on");
        
            end
        
        end


        function actualizarFrecuencia(app)

            if isempty(app.x)
                return;
            end
        
            if isempty(app.y)
                return;
            end
        
            Fs = app.Fs;
        
            [f1, mag1, ~] = espectroUnilateral(app, app.x, Fs);
            [f2, mag2, ~] = espectroUnilateral(app, app.y, Fs);
        
            % ============================================================
            % Selección de unidad del eje horizontal
            % ============================================================
            if app.radmuestraCheckBox.Value == true
        
                eje1 = 2*pi*f1/Fs;
                eje2 = 2*pi*f2/Fs;
        
                etiquetaX = "Frecuencia [rad/muestra]";
                limiteX = pi;
        
            else
        
                eje1 = f1;
                eje2 = f2;
        
                etiquetaX = "Frecuencia [Hz]";
                limiteX = Fs/2;
        
            end
        
            % ============================================================
            % Magnitud original
            % ============================================================
            plot(app.UIAxes_2, eje1, mag1, "LineWidth", 1.2);
            grid(app.UIAxes_2, "on");
            title(app.UIAxes_2, "Magnitud - Original");
            xlabel(app.UIAxes_2, etiquetaX);
            ylabel(app.UIAxes_2, "|X(f)|");
            xlim(app.UIAxes_2, [0 limiteX]);
            ylim(app.UIAxes_2, [0 max(mag1)*1.1 + eps]);
        
            % ============================================================
            % Magnitud procesada
            % ============================================================
            plot(app.UIAxes_3, eje2, mag2, "LineWidth", 1.2);
            grid(app.UIAxes_3, "on");
            title(app.UIAxes_3, "Magnitud - Procesada");
            xlabel(app.UIAxes_3, etiquetaX);
            ylabel(app.UIAxes_3, "|Y(f)|");
            xlim(app.UIAxes_3, [0 limiteX]);
            ylim(app.UIAxes_3, [0 max(mag2)*1.1 + eps]);
        
            % ============================================================
            % Respuesta en frecuencia del filtro
            % ============================================================
            if app.filtroDisenado == true
                graficarRespuestaFiltro(app);
            end
        
        end

    end
       
    

    % Callbacks that handle component events
    methods (Access = private)

        % Button pushed function: ConectarDesconectarButton
        function ConectarDesconectarButtonPushed(app, event)
       
            if app.conectado == false
        
                puerto = app.PuertosCOMdisponiblesDropDown.Value;
        
                try
                    app.s = serialport(puerto, 115200);
                    app.s.Timeout = 20;
                    flush(app.s);
        
                    app.conectado = true;
        
                    app.EstadoLabel.Text = "Conectado";
                    app.StatusLamp.Color = [0 1 0];
                    app.ConectarDesconectarButton.Text = "Desconectar";
        
                catch ME
                    app.conectado = false;
        
                    app.EstadoLabel.Text = "Error de conexión";
                    app.StatusLamp.Color = [1 0 0];
                    app.ConectarDesconectarButton.Text = "Conectar";
        
                    uialert(app.UIFigure, ME.message, "Error de conexión");
                end
        
            else
        
                try
                    if ~isempty(app.s)
                        flush(app.s);
                        delete(app.s);
                        app.s = [];
                    end
                catch
                    app.s = [];
                end
        
                app.conectado = false;
        
                app.EstadoLabel.Text = "Desconectado";
                app.StatusLamp.Color = [1 0 0];
                app.ConectarDesconectarButton.Text = "Conectar";
        
            end
        end

        % Button pushed function: RefrescarPuertosButton
        function RefrescarPuertosButtonPushed(app, event)

            puertos = serialportlist("available");
    
            if ~isempty(puertos)
    
                app.PuertosCOMdisponiblesDropDown.Items = puertos;
                app.PuertosCOMdisponiblesDropDown.Value = puertos(1);
    
                app.EstadoLabel.Text = "Puertos detectados";
                app.StatusLamp.Color = [1 1 0];
    
            else
    
                app.PuertosCOMdisponiblesDropDown.Items = {};
                app.EstadoLabel.Text = "Sin puertos";
                app.StatusLamp.Color = [1 0 0];
    
            end
        end

        % Button pushed function: CapturadedatosButton
        function CapturadedatosButtonPushed(app, event)
     
            if app.conectado == false
                uialert(app.UIFigure, "Primero conecta la Nucleo.", "Error");
                return;
            end
        
            canal = app.CanalADCDropDown.Value;
        
            if canal ~= "A0"
                uialert(app.UIFigure, "Por ahora solo está habilitado el canal A0 / PA0.", "Canal ADC no disponible");
                return;
            end
        
            % Número de muestras configurable desde la interfaz
            N = round(app.NumerodemuestrasEditField.Value);
            Fs = round(app.FsHzEditField.Value);
        
            if N < 100 || N > 1000
                uialert(app.UIFigure, "El número de muestras debe estar entre 100 y 1000.", "N inválido");
                return;
            end
        
            if Fs < 100 || Fs > 5000
                uialert(app.UIFigure, "Fs debe estar entre 100 y 5000 Hz.", "Fs inválida");
                return;
            end
        
            app.N = N;
            app.Fs = Fs;
            app.NumerodemuestrasEditField.Value = N;
            app.FsHzEditField.Value = Fs;
        
            try
                flush(app.s);
        
                % Enviar cantidad de muestras a la Nucleo
                writeline(app.s, sprintf("N,%d", N));
                respuestaN = strtrim(readline(app.s));
        
                if ~startsWith(respuestaN, "OK_N")
                    uialert(app.UIFigure, ...
                        "La Nucleo no aceptó el número de muestras. Respuesta: " + respuestaN, ...
                        "Error N");
                    return;
                end
        
                % Solicitar captura
                writeline(app.s, "C");
        
                linea = strtrim(readline(app.s));
        
                if linea ~= "OK_CAPTURA"
                    uialert(app.UIFigure, "No se recibió OK_CAPTURA. Se recibió: " + linea, "Error");
                    return;
                end
        
                linea = strtrim(readline(app.s));
        
                while linea ~= "BEGIN"
                    linea = strtrim(readline(app.s));
                end
        
                x = zeros(1, N);
        
                for k = 1:N
                    dato = strtrim(readline(app.s));
                    x(k) = str2double(dato);
                end
        
                fin = strtrim(readline(app.s));
        
                if fin ~= "END"
                    uialert(app.UIFigure, "Captura incompleta. No se recibió END.", "Error");
                    return;
                end
        
                % Guardar datos en la app
                app.x = x;
                app.datosCapturados = x;
        
                graficarTiempo(app);
                procesarConLambda(app);
        
                app.EstadoLabel.Text = "Captura completada: " + string(N) + " muestras";
        
            catch ME
                uialert(app.UIFigure, ...
                    "No hubo respuesta correcta de la Nucleo. Verifica que el firmware esté corriendo." + newline + ME.message, ...
                    "Error de captura");
        
                app.EstadoLabel.Text = "Error en captura";
            end
        end

