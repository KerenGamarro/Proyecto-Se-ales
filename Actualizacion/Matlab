        % Button pushed function: AjustarGraficaButton
        function AjustarGraficaButtonPushed(app, event)
        
            if isempty(app.x)
                uialert(app.UIFigure, "No hay señal cargada o capturada para ajustar.", "Sin datos");
                return;
            end
        
            % Obtener datos actuales
            x = app.x;
            N = length(x);
            Fs = app.Fs;
        
            % Vector de tiempo
            t = (0:N-1)/Fs;
        
            % Volver a graficar la señal completa
            plot(app.UIAxes, t, x, "LineWidth", 1.2);
            grid(app.UIAxes, "on");
        
            title(app.UIAxes, "Señal ajustada");
            xlabel(app.UIAxes, "Tiempo [s]");
            ylabel(app.UIAxes, "Amplitud");
        
            % Ajustar límites automáticamente
            xlim(app.UIAxes, [t(1) t(end)]);
        
            ymin = min(x);
            ymax = max(x);
        
            % Margen vertical para que la señal no quede pegada al borde
            margen = 0.1 * (ymax - ymin);
        
            if margen == 0
                margen = 1;
            end
        
            ylim(app.UIAxes, [ymin - margen, ymax + margen]);
        
            app.EstadoLabel.Text = "Gráfica ajustada";
        end

