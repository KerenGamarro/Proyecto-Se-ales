        % Button pushed function: CargararchivosvariosButton
        function CargararchivosvariosButtonPushed(app, event)
        
            [file, path] = uigetfile( ...
                {"*.mat;*.csv;*.txt;*.wav;*.mp3", "Archivos compatibles (*.mat, *.csv, *.txt, *.wav, *.mp3)"; ...
                 "*.mat", "Archivo MAT (*.mat)"; ...
                 "*.csv", "Archivo CSV (*.csv)"; ...
                 "*.txt", "Archivo TXT (*.txt)"; ...
                 "*.wav;*.mp3", "Audio (*.wav, *.mp3)"}, ...
                 "Seleccionar archivo");
        
            if isequal(file, 0)
                return;
            end
        
            archivo = fullfile(path, file);
            [~, ~, ext] = fileparts(archivo);
        
            try
        
                switch lower(ext)
        
                    case ".mat"
        
                        datos = load(archivo);
        
                        if isfield(datos, "x")
                            x = datos.x;
                        else
                            uialert(app.UIFigure, "El archivo MAT debe contener una variable llamada x.", "Error MAT");
                            return;
                        end
        
                        if isfield(datos, "Fs")
                            Fs = datos.Fs;
                        else
                            Fs = app.FsHzEditField.Value;
                        end
        
                        app.audioCargado = false;
        
                    case ".csv"
        
                        tabla = readtable(archivo);
        
                        if any(strcmpi(tabla.Properties.VariableNames, "x"))
                            idx = find(strcmpi(tabla.Properties.VariableNames, "x"), 1);
                            x = tabla{:, idx};
        
                        elseif any(strcmpi(tabla.Properties.VariableNames, "Original"))
                            idx = find(strcmpi(tabla.Properties.VariableNames, "Original"), 1);
                            x = tabla{:, idx};
        
                        else
                            x = [];
        
                            for k = 1:width(tabla)
                                columna = tabla{:, k};
        
                                if isnumeric(columna)
                                    x = columna;
                                    break;
                                end
                            end
        
                            if isempty(x)
                                uialert(app.UIFigure, "No se encontró una columna numérica válida en el CSV.", "Error CSV");
                                return;
                            end
                        end
        
                        Fs = app.FsHzEditField.Value;
                        app.audioCargado = false;
        
                    case ".txt"
        
                        datos_txt = readmatrix(archivo);
        
                        if isempty(datos_txt)
                            uialert(app.UIFigure, "El archivo TXT no contiene datos numéricos válidos.", "Error TXT");
                            return;
                        end
        
                        x = datos_txt(:, 1);
                        Fs = app.FsHzEditField.Value;
                        app.audioCargado = false;
        
                    case {".wav", ".mp3"}
        
                        [x, Fs] = audioread(archivo);
        
                        % Si el audio viene estéreo, se convierte a mono
                        if size(x, 2) > 1
                            x = mean(x, 2);
                        end
        
                        app.audioCargado = true;
        
                    otherwise
        
                        uialert(app.UIFigure, "Formato no compatible.", "Error");
                        return;
        
                end
        
                % Guardar señal en la app
                x = x(:).';
        
                app.x = x;
                app.y = [];
                app.Fs = round(Fs);
                app.N = length(x);
                app.datosCapturados = x;
        
                app.FsHzEditField.Value = app.Fs;
        
                if app.N <= 1000
                    app.NumerodemuestrasEditField.Value = app.N;
                else
                    app.NumerodemuestrasEditField.Value = 1000;
                end
        
                % Graficar en pestañas generales
                graficarTiempo(app);
        
                % Graficar en pestaña Audio
                graficarAudio(app);
        
                app.EstadoLabel.Text = "Archivo cargado: " + string(ext);
        
            catch ME
        
                uialert(app.UIFigure, ...
                    "No se pudo cargar el archivo." + newline + ME.message, ...
                    "Error de carga");
        
                app.EstadoLabel.Text = "Error al cargar archivo";
        
            end
        
        
        end

        % Button pushed function: AudiooriginalButton
        function AudiooriginalButtonPushed(app, event)
        
            if isempty(app.x)
                uialert(app.UIFigure, "No hay señal original para reproducir.", "Sin audio");
                return;
            end
        
            x = app.x(:);
            x = x - mean(x);
        
            maxAbs = max(abs(x));
        
            if maxAbs > 0
                x = x / maxAbs;
            end
        
            soundsc(x, app.Fs);
        
            app.EstadoLabel.Text = "Reproduciendo audio original";
        end

        % Button pushed function: AudioProcesadoButton
        function AudioProcesadoButtonPushed(app, event)
        
            if isempty(app.y)
                uialert(app.UIFigure, "No hay señal procesada para reproducir.", "Sin audio procesado");
                return;
            end
        
            y = app.y(:);
            y = y - mean(y);
        
            maxAbs = max(abs(y));
        
            if maxAbs > 0
                y = y / maxAbs;
            end
        
            soundsc(y, app.Fs);
        
            app.EstadoLabel.Text = "Reproduciendo audio procesado";
        
        end

        % Button pushed function: DetenerAudioButton
        function DetenerAudioButtonPushed(app, event)

            clear sound;
        
            app.EstadoLabel.Text = "Audio detenido";
        end
