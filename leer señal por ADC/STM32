/* USER CODE BEGIN Header */
/*
 * PROYECTO FINAL - ETAPA 1
 * Comunicación STM32 Nucleo-F446RE con Matlab
 *
 * Objetivo:
 * Leer una señal analógica por ADC y enviarla por UART
 * para que Matlab pueda graficarla.
 *
 * Fs = 1000 Hz
 */
/* USER CODE END Header */

/* Includes ------------------------------------------------------------------*/
#include "main.h"

/* Private includes ----------------------------------------------------------*/
/* USER CODE BEGIN Includes */
#include <stdio.h>
/* USER CODE END Includes */

/* Private variables ---------------------------------------------------------*/
ADC_HandleTypeDef hadc1;
DAC_HandleTypeDef hdac;
TIM_HandleTypeDef htim10;
UART_HandleTypeDef huart2;

/* USER CODE BEGIN PV */

// Valor leído del ADC
uint16_t adc_value = 0;

// Buffer para enviar datos por UART
char uart_buffer[30];
uint16_t uart_len = 0;

// Frecuencia de muestreo
uint16_t Fs = 1000;   // 1000 Hz

uint32_t timer_clk;
uint32_t pclk;

/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
static void MX_ADC1_Init(void);
static void MX_TIM10_Init(void);
static void MX_DAC_Init(void);

/* USER CODE BEGIN 0 */

// Interrupción del timer
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
	if (htim->Instance == TIM10)
	{
		// 1. Iniciar conversión ADC
		HAL_ADC_Start(&hadc1);

		// 2. Esperar conversión
		HAL_ADC_PollForConversion(&hadc1, 10);

		// 3. Leer valor ADC de 12 bits: 0 a 4095
		adc_value = HAL_ADC_GetValue(&hadc1);

		// 4. Enviar dato por UART hacia Matlab
		uart_len = sprintf(uart_buffer, "%u\r\n", adc_value);
		HAL_UART_Transmit(&huart2, (uint8_t*)uart_buffer, uart_len, 10);

		// 5. Sacar el mismo valor por DAC
		HAL_DAC_SetValue(&hdac, DAC_CHANNEL_1, DAC_ALIGN_12B_R, adc_value);
	}
}

/* USER CODE END 0 */

int main(void)
{
  HAL_Init();

  SystemClock_Config();

  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_ADC1_Init();
  MX_TIM10_Init();
  MX_DAC_Init();

  // Iniciar DAC
  HAL_DAC_Start(&hdac, DAC_CHANNEL_1);

  // Iniciar timer con interrupción
  HAL_TIM_Base_Start_IT(&htim10);

  while (1)
  {
	  // El trabajo principal ocurre en la interrupción del TIM10
  }
}

