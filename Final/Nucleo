int main(void)
{
  HAL_Init();

  SystemClock_Config();

  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_ADC1_Init();
  MX_TIM10_Init();
  MX_DAC_Init();

  HAL_DAC_Start(&hdac, DAC_CHANNEL_1);
  HAL_TIM_Base_Start_IT(&htim10);

  while (1)
  {
	  if (HAL_UART_Receive(&huart2, &rx_data, 1, 10) == HAL_OK)
	  {
		  if (rx_data == '\n' || rx_data == '\r')
		  {
			  if (rx_index > 0)
			  {
				  rx_buffer[rx_index] = '\0';
				  procesar_comando(rx_buffer);
				  rx_index = 0;
			  }
		  }
		  else
		  {
			  if (rx_index < sizeof(rx_buffer) - 1)
			  {
				  rx_buffer[rx_index++] = rx_data;
			  }
		  }
	  }

	  if (capture_done == 1)
	  {
	  	capture_done = 0;

	  	HAL_UART_Transmit(&huart2, (uint8_t*)"BEGIN\r\n", 7, HAL_MAX_DELAY);

	  	for (uint16_t i = 0; i < n_samples_cfg; i++)
	  	{
	  		uart_len = sprintf(uart_buffer, "%u\r\n", adc_buffer[i]);
	  		HAL_UART_Transmit(&huart2, (uint8_t*)uart_buffer, uart_len, HAL_MAX_DELAY);
	  	}

	  	HAL_UART_Transmit(&huart2, (uint8_t*)"END\r\n", 5, HAL_MAX_DELAY);
	  }
  }
}

