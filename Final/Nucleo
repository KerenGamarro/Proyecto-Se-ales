void reiniciar_memorias_filtro(void)
{
	for (uint8_t i = 0; i < MAX_COEF; i++)
	{
		x_hist[i] = 0.0f;
		y_hist[i] = 0.0f;
	}

	y_n_1 = 0.0f;
}

float aplicar_iir_general(float entrada) //aqui inicia el uso de los coeficientes
{
	float salida = 0.0f;

	// Desplazar historial de entradas
	for (int i = MAX_COEF - 1; i > 0; i--)
	{
		x_hist[i] = x_hist[i - 1];
	}

	x_hist[0] = entrada;

	// Parte de entradas: b0x[n] + b1x[n-1] + ...
	for (uint8_t i = 0; i < nB; i++)
	{
		salida += b_coef[i] * x_hist[i];
	}

	// Parte recursiva: -a1y[n-1] - a2y[n-2] ...
	for (uint8_t i = 1; i < nA; i++)
	{
		salida -= a_coef[i] * y_hist[i - 1];
	}

	// Normalizar si a0 no es 1
	if (a_coef[0] != 0.0f)
	{
		salida = salida / a_coef[0];
	}

	// Desplazar historial de salidas
	for (int i = MAX_COEF - 1; i > 0; i--)
	{
		y_hist[i] = y_hist[i - 1];
	}

	y_hist[0] = salida;

	return salida;
}

void procesar_comando(char *cmd)
{
	if (cmd[0] == 'C')
	{
		HAL_UART_Transmit(&huart2, (uint8_t*)"OK_CAPTURA\r\n", 12, HAL_MAX_DELAY);

		sample_index = 0;
		capture_done = 0;
		capture_active = 1;
	}

	else if (strncmp(cmd, "N,", 2) == 0)
	{
		uint16_t nuevo_N = (uint16_t)atoi(&cmd[2]);

		if (capture_active == 1)
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_N_BUSY\r\n", 12, HAL_MAX_DELAY);
		}
		else if (nuevo_N >= 100 && nuevo_N <= MAX_SAMPLES)
		{
			n_samples_cfg = nuevo_N;

			uart_len = sprintf(uart_buffer, "OK_N=%u\r\n", n_samples_cfg);
			HAL_UART_Transmit(&huart2, (uint8_t*)uart_buffer, uart_len, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_N\r\n", 7, HAL_MAX_DELAY);
		}
	}

	else if (cmd[0] == 'L')
	{
		float nuevo_lambda = atof(&cmd[2]);

		if (nuevo_lambda >= 0.0f && nuevo_lambda < 1.0f)
		{
			lambda = nuevo_lambda;
			coeficientes_listos = 0; // vuelve al filtro simple con lambda

			uint16_t lambda_mil = (uint16_t)(lambda * 1000.0f);
			uart_len = sprintf(uart_buffer, "OK_LAMBDA=%u/1000\r\n", lambda_mil);
			HAL_UART_Transmit(&huart2, (uint8_t*)uart_buffer, uart_len, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_LAMBDA\r\n", 12, HAL_MAX_DELAY);
		}
	}

	else if (cmd[0] == 'F')
	{
		uint8_t nuevo_estado = (uint8_t)atoi(&cmd[2]);

		if (nuevo_estado == 0 || nuevo_estado == 1)
		{
			filter_enable = nuevo_estado;

			if (filter_enable == 1)
			{
				HAL_UART_Transmit(&huart2, (uint8_t*)"OK_FILTRO_ON\r\n", 14, HAL_MAX_DELAY);
			}
			else
			{
				HAL_UART_Transmit(&huart2, (uint8_t*)"OK_FILTRO_OFF\r\n", 15, HAL_MAX_DELAY);
			}
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_FILTRO\r\n", 12, HAL_MAX_DELAY);
		}
	}

	else if (strncmp(cmd, "NB,", 3) == 0)
	{
		nB_temp = (uint8_t)atoi(&cmd[3]);

		if (nB_temp >= 1 && nB_temp <= MAX_COEF)
		{
			for (uint8_t i = 0; i < MAX_COEF; i++)
			{
				b_temp[i] = 0.0f;
			}

			b_recibidos = 0;
			HAL_UART_Transmit(&huart2, (uint8_t*)"OK_NB\r\n", 7, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_NB\r\n", 8, HAL_MAX_DELAY);
		}
	}

	else if (cmd[0] == 'B')
	{
		int indice = atoi(&cmd[2]);
		char *p = strchr(&cmd[2], ',');

		if (p != NULL && indice >= 1 && indice <= nB_temp && indice <= MAX_COEF)
		{
			float valor = atof(p + 1);
			b_temp[indice - 1] = valor;
			b_recibidos++;

			HAL_UART_Transmit(&huart2, (uint8_t*)"OK_B\r\n", 6, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_B\r\n", 7, HAL_MAX_DELAY);
		}
	}

	else if (strncmp(cmd, "NA,", 3) == 0)
	{
		nA_temp = (uint8_t)atoi(&cmd[3]);

		if (nA_temp >= 1 && nA_temp <= MAX_COEF)
		{
			for (uint8_t i = 0; i < MAX_COEF; i++)
			{
				a_temp[i] = 0.0f;
			}

			a_recibidos = 0;
			HAL_UART_Transmit(&huart2, (uint8_t*)"OK_NA\r\n", 7, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_NA\r\n", 8, HAL_MAX_DELAY);
		}
	}

	else if (cmd[0] == 'A')
	{
		int indice = atoi(&cmd[2]);
		char *p = strchr(&cmd[2], ',');

		if (p != NULL && indice >= 1 && indice <= nA_temp && indice <= MAX_COEF)
		{
			float valor = atof(p + 1);
			a_temp[indice - 1] = valor;
			a_recibidos++;

			HAL_UART_Transmit(&huart2, (uint8_t*)"OK_A\r\n", 6, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_A\r\n", 7, HAL_MAX_DELAY);
		}
	}

	else if (strcmp(cmd, "END_COEF") == 0)
	{
		if (nB_temp >= 1 && nA_temp >= 1 && a_temp[0] != 0.0f)
		{
			nB = nB_temp;
			nA = nA_temp;

			for (uint8_t i = 0; i < MAX_COEF; i++)
			{
				b_coef[i] = b_temp[i];
				a_coef[i] = a_temp[i];
			}

			coeficientes_listos = 1;
			filter_enable = 1;
			reiniciar_memorias_filtro();

			HAL_UART_Transmit(&huart2, (uint8_t*)"OK_COEF\r\n", 9, HAL_MAX_DELAY);
		}
		else
		{
			HAL_UART_Transmit(&huart2, (uint8_t*)"ERR_COEF\r\n", 10, HAL_MAX_DELAY);
		}
	}
}

void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
	if (htim->Instance == TIM10)
	{
		// ADC siempre activo para que el DAC pueda verse en osciloscopio
		HAL_ADC_Start(&hadc1);
		HAL_ADC_PollForConversion(&hadc1, 10);
		adc_value = HAL_ADC_GetValue(&hadc1);

		x_n = (float)adc_value;

		if (filter_enable == 0)
		{
			y_n = x_n;
		}
		else
		{
			if (coeficientes_listos == 1)
			{
				y_n = aplicar_iir_general(x_n);
			}
			else
			{
				y_n = (1.0f - lambda)*x_n + lambda*y_n_1;
				y_n_1 = y_n;
			}
		}

		if (y_n > 4095.0f) y_n = 4095.0f;
		if (y_n < 0.0f)    y_n = 0.0f;

		HAL_DAC_SetValue(&hdac, DAC_CHANNEL_1, DAC_ALIGN_12B_R, (uint16_t)y_n);

		if (capture_active == 1)
		{
			if (sample_index < n_samples_cfg && sample_index < MAX_SAMPLES)
			{
				adc_buffer[sample_index] = (uint16_t)y_n;
				sample_index++;
			}

			if (sample_index >= n_samples_cfg)
			{
				capture_active = 0;
				capture_done = 1;
			}
		}
	}
}

