#define MAX_SAMPLES 1000
#define MAX_COEF 11   // Permite hasta orden 10: b0...b10 / a0...a10

uint16_t adc_value = 0;
uint16_t adc_buffer[MAX_SAMPLES];

// Cantidad de muestras configurable desde Matlab.
// Por seguridad se limita a MAX_SAMPLES.
volatile uint16_t n_samples_cfg = 1000;

volatile uint16_t sample_index = 0;
volatile uint8_t capture_active = 0;
volatile uint8_t capture_done = 0;

uint8_t rx_data;
char rx_buffer[60];
uint8_t rx_index = 0;

char uart_buffer[80];
uint16_t uart_len = 0;

uint16_t Fs = 1000;

uint32_t timer_clk;
uint32_t pclk;

// Filtro simple con lambda, queda como respaldo
float lambda = 0.90f;
float x_n = 0.0f;
float y_n = 0.0f;
float y_n_1 = 0.0f;

// Filtro ON/OFF
uint8_t filter_enable = 1;

// Coeficientes IIR generales enviados desde MATLAB
float b_coef[MAX_COEF] = {1.0f};
float a_coef[MAX_COEF] = {1.0f};

float b_temp[MAX_COEF] = {0.0f};
float a_temp[MAX_COEF] = {0.0f};

float x_hist[MAX_COEF] = {0.0f};
float y_hist[MAX_COEF] = {0.0f};

uint8_t nB = 1;
uint8_t nA = 1;

uint8_t nB_temp = 0;
uint8_t nA_temp = 0;

uint8_t b_recibidos = 0;
uint8_t a_recibidos = 0;

uint8_t coeficientes_listos = 0;

